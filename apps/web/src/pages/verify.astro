---
import Base from "../layouts/Base.astro";
const token = Astro.url.searchParams.get("token");
const API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3001";
---
<Base title="Verify">
  <div class="card">
    <h1 class="text-2xl font-semibold">Email verification</h1>
    <p class="mt-2 text-slate-300" id="message">Verifying...</p>
    <p class="mt-4"><a href="/login" class="text-indigo-400 hover:underline hidden" id="loginLink">Go to login</a></p>
  </div>
  <script define:vars={{ API_BASE }}>
    const message = document.getElementById("message");
    const loginLink = document.getElementById("loginLink");
    const params = new URLSearchParams(window.location.search);
    const token = params.get("token");
    
    if (token) {
      fetch(`${API_BASE}/api/v1/auth/verify?token=${encodeURIComponent(token)}`, {
        credentials: "include"
      })
        .then(res => res.json())
        .then(result => {
          if (result.ok) {
            message.textContent = "✓ Email verified! You can login now.";
            message.className = "mt-2 text-green-400";
            loginLink.classList.remove("hidden");
          } else {
            throw new Error(result.error || "Verification failed");
          }
        })
        .catch(err => {
          message.textContent = err.message;
          message.className = "mt-2 text-red-400";
        });
    } else {
      message.textContent = "Invalid verification link";
      message.className = "mt-2 text-red-400";
    }
  </script>
</Base>
