---
import Base from "../layouts/Base.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3001";
---
<Base title="Forgot Password">
  <div class="max-w-md">
    <h1 class="text-2xl font-semibold">Forgot Password</h1>
    <p class="mt-2 text-slate-400">Enter your email and we'll send you a link to reset your password.</p>
    <form class="mt-6 space-y-3" id="forgotForm" method="POST" action="#">
      <input class="input" name="email" placeholder="Email" type="email" required autocomplete="email" />
      <button class="btn w-full" type="submit" id="submitBtn">Send Reset Link</button>
      <p class="text-sm text-slate-400" id="message"></p>
    </form>
    <p class="mt-4 text-sm text-slate-400">
      Remember your password? <a href="/login" class="text-indigo-400 hover:underline">Login</a>
    </p>
  </div>
  <script define:vars={{ API_BASE }}>
    const form = document.getElementById("forgotForm");
    const message = document.getElementById("message");
    const submitBtn = document.getElementById("submitBtn");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        email: formData.get("email"),
      };
      
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";
      message.textContent = "";

      try {
        const res = await fetch(`${API_BASE}/api/v1/auth/forgot-password`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (!res.ok) throw new Error(result.error || "Request failed");
        
        message.textContent = "If an account with that email exists, we've sent a password reset link.";
        message.className = "text-sm text-green-400";
        form.reset();
      } catch (err) {
        message.textContent = err.message;
        message.className = "text-sm text-red-400";
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Reset Link";
      }
    });
  </script>
</Base>
