---
import Protected from "../layouts/Protected.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3001";
---
<Protected title="Dashboard">
  <div class="space-y-6">
    <!-- Loading State -->
    <div id="loading" class="card">
      <p class="text-slate-400">Loading dashboard...</p>
    </div>

    <!-- No Syndicate CTA -->
    <div id="noSyndicateCta" class="card hidden">
      <h1 class="text-2xl font-semibold mb-4">Welcome to SyndCal!</h1>
      <p class="text-slate-400 mb-6">You're not part of any syndicate yet. To start reserving launch days, you need to join or create a syndicate.</p>
      <div class="flex gap-4">
        <a href="/syndicates" class="btn">Create a Syndicate</a>
        <a href="/syndicates" class="btn bg-slate-700 hover:bg-slate-600">Join a Syndicate</a>
      </div>
    </div>

    <!-- Calendar View -->
    <div id="calendarView" class="hidden">
      <!-- Header with month navigation -->
      <div class="card mb-4">
        <div class="flex items-center justify-between">
          <button id="prevMonth" class="btn bg-slate-700 hover:bg-slate-600">← Previous</button>
          <h1 id="currentMonth" class="text-2xl font-semibold"></h1>
          <button id="nextMonth" class="btn bg-slate-700 hover:bg-slate-600">Next →</button>
        </div>
      </div>

      <!-- Calendar Grid -->
      <div class="card">
        <!-- Weekday headers -->
        <div class="grid grid-cols-7 gap-1 mb-2">
          <div class="text-center text-sm font-medium text-slate-400 py-2">Sun</div>
          <div class="text-center text-sm font-medium text-slate-400 py-2">Mon</div>
          <div class="text-center text-sm font-medium text-slate-400 py-2">Tue</div>
          <div class="text-center text-sm font-medium text-slate-400 py-2">Wed</div>
          <div class="text-center text-sm font-medium text-slate-400 py-2">Thu</div>
          <div class="text-center text-sm font-medium text-slate-400 py-2">Fri</div>
          <div class="text-center text-sm font-medium text-slate-400 py-2">Sat</div>
        </div>

        <!-- Calendar days -->
        <div id="calendarGrid" class="grid grid-cols-7 gap-1">
          <!-- Days will be inserted here -->
        </div>
      </div>

      <!-- Syndicate Legend -->
      <div id="syndicateLegend" class="card mt-4">
        <h3 class="text-lg font-semibold mb-3">Syndicates</h3>
        <div id="legendItems" class="flex flex-wrap gap-4">
          <!-- Legend items will be inserted here -->
        </div>
      </div>

      <!-- Create Reservation Modal -->
      <div id="createModal" class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50">
        <div class="card w-full max-w-md mx-4">
          <h2 class="text-xl font-semibold mb-4">Create Reservation</h2>
          <form id="createReservationForm" class="space-y-4">
            <input type="hidden" id="selectedDate" />
            
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-1">Start Date</label>
              <input type="date" id="startDate" class="input" required />
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-300 mb-1">End Date</label>
              <input type="date" id="endDate" class="input" required />
            </div>

            <div id="dateError" class="hidden">
              <p class="text-sm text-red-400"></p>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-300 mb-1">Syndicate</label>
              <select id="syndicateSelect" class="input" required>
                <!-- Options will be populated -->
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-300 mb-1">Title</label>
              <input type="text" id="reservationTitle" class="input" placeholder="e.g., Product Launch" required />
            </div>

            <div class="flex gap-3">
              <button type="submit" class="btn flex-1">Create Reservation</button>
              <button type="button" id="cancelModal" class="btn bg-slate-700 hover:bg-slate-600 flex-1">Cancel</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ API_BASE }}>
    const API = API_BASE;
    let currentData = null;
    let currentDate = new Date();
    let selectedSyndicateId = null;

    const loadingEl = document.getElementById('loading');
    const noSyndicateCtaEl = document.getElementById('noSyndicateCta');
    const calendarViewEl = document.getElementById('calendarView');
    const calendarGridEl = document.getElementById('calendarGrid');
    const currentMonthEl = document.getElementById('currentMonth');
    const legendItemsEl = document.getElementById('legendItems');
    const createModalEl = document.getElementById('createModal');
    const createFormEl = document.getElementById('createReservationForm');
    const selectedDateInput = document.getElementById('selectedDate');
    const startDateInput = document.getElementById('startDate');
    const endDateInput = document.getElementById('endDate');
    const dateErrorEl = document.getElementById('dateError');
    const dateErrorText = dateErrorEl.querySelector('p');
    const syndicateSelectEl = document.getElementById('syndicateSelect');
    const reservationTitleInput = document.getElementById('reservationTitle');
    const cancelModalBtn = document.getElementById('cancelModal');

    const csrfToken = localStorage.getItem("csrfToken");

    async function request(path, options = {}) {
      const headers = { "Content-Type": "application/json" };
      if (csrfToken) headers["X-CSRF-Token"] = csrfToken;
      const res = await fetch(`${API}${path}`, {
        credentials: "include",
        headers,
        ...options,
      });
      const data = await res.json();
      if (res.status === 401) {
        localStorage.removeItem("csrfToken");
        window.location.href = "/login?expired=1";
        throw new Error("Session expired");
      }
      if (!res.ok) throw new Error(data.error || "Request failed");
      if (data?.csrfToken) {
        localStorage.setItem("csrfToken", data.csrfToken);
      }
      return data;
    }

    // Generate consistent colors for syndicates
    function getSyndicateColor(syndicateId) {
      const colors = [
        'bg-indigo-500',
        'bg-purple-500',
        'bg-pink-500',
        'bg-red-500',
        'bg-orange-500',
        'bg-yellow-500',
        'bg-green-500',
        'bg-teal-500',
        'bg-cyan-500',
        'bg-blue-500',
      ];
      let hash = 0;
      for (let i = 0; i < syndicateId.length; i++) {
        hash = ((hash << 5) - hash) + syndicateId.charCodeAt(i);
        hash = hash & hash;
      }
      return colors[Math.abs(hash) % colors.length];
    }

    function getSyndicateColorHex(syndicateId) {
      const colorMap = {
        'bg-indigo-500': '#6366f1',
        'bg-purple-500': '#a855f7',
        'bg-pink-500': '#ec4899',
        'bg-red-500': '#ef4444',
        'bg-orange-500': '#f97316',
        'bg-yellow-500': '#eab308',
        'bg-green-500': '#22c55e',
        'bg-teal-500': '#14b8a6',
        'bg-cyan-500': '#06b6d4',
        'bg-blue-500': '#3b82f6',
      };
      return colorMap[getSyndicateColor(syndicateId)];
    }

    function renderCalendar(year, month) {
      const firstDay = new Date(year, month, 1);
      const lastDay = new Date(year, month + 1, 0);
      const prevLastDay = new Date(year, month, 0);
      
      const startDayOfWeek = firstDay.getDay();
      const totalDays = lastDay.getDate();
      const prevMonthDays = prevLastDay.getDate();

      const today = new Date();
      const isCurrentMonth = today.getFullYear() === year && today.getMonth() === month;

      calendarGridEl.innerHTML = '';

      // Previous month days
      for (let i = startDayOfWeek - 1; i >= 0; i--) {
        const dayEl = document.createElement('div');
        dayEl.className = 'min-h-24 p-2 bg-slate-900/30 border border-slate-800/50 rounded-lg opacity-50';
        dayEl.innerHTML = `<div class="text-sm text-slate-500">${prevMonthDays - i}</div>`;
        calendarGridEl.appendChild(dayEl);
      }

      // Current month days
      for (let day = 1; day <= totalDays; day++) {
        const date = new Date(year, month, day);
        const dateStr = date.toISOString().split('T')[0];
        const isToday = isCurrentMonth && day === today.getDate();
        
        const dayEl = document.createElement('div');
        dayEl.className = `min-h-24 p-2 border border-slate-800 rounded-lg cursor-pointer hover:border-slate-600 transition-colors ${
          isToday ? 'bg-slate-800 border-slate-600' : 'bg-slate-900/50'
        }`;
        
        // Day number
        const dayNumberEl = document.createElement('div');
        dayNumberEl.className = `text-sm font-medium mb-1 ${
          isToday ? 'text-indigo-400' : 'text-slate-300'
        }`;
        dayNumberEl.textContent = day;
        dayEl.appendChild(dayNumberEl);

        // Find reservations for this day
        const dayReservations = currentData.reservations.filter(r => {
          const rDate = new Date(r.startDate).toISOString().split('T')[0];
          return rDate === dateStr;
        });

        // Render reservations
        dayReservations.forEach(r => {
          const colorClass = getSyndicateColor(r.syndicateId);
          const isUserReservation = r.createdById === currentData.user.id;
          
          const resEl = document.createElement('div');
          resEl.className = `text-xs px-2 py-1 rounded mb-1 truncate ${colorClass} text-white`;
          resEl.title = `${r.title} (${r.syndicate.name})${isUserReservation ? ' - You' : ''}`;
          resEl.textContent = r.title;
          if (isUserReservation) {
            resEl.classList.add('ring-2', 'ring-white');
          }
          dayEl.appendChild(resEl);
        });

        // Click to create reservation
        dayEl.addEventListener('click', (e) => {
          if (!e.target.classList.contains('ring-2')) {
            openCreateModal(dateStr);
          }
        });

        calendarGridEl.appendChild(dayEl);
      }

      // Next month days (fill remaining)
      const totalCells = startDayOfWeek + totalDays;
      const remainingCells = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
      for (let i = 1; i <= remainingCells; i++) {
        const dayEl = document.createElement('div');
        dayEl.className = 'min-h-24 p-2 bg-slate-900/30 border border-slate-800/50 rounded-lg opacity-50';
        dayEl.innerHTML = `<div class="text-sm text-slate-500">${i}</div>`;
        calendarGridEl.appendChild(dayEl);
      }

      // Update month display
      const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 
                         'July', 'August', 'September', 'October', 'November', 'December'];
      currentMonthEl.textContent = `${monthNames[month]} ${year}`;
    }

    function renderLegend() {
      legendItemsEl.innerHTML = '';
      
      currentData.memberships.forEach(m => {
        const colorClass = getSyndicateColor(m.syndicateId);
        const itemEl = document.createElement('div');
        itemEl.className = 'flex items-center gap-2';
        itemEl.innerHTML = `
          <div class="w-4 h-4 rounded ${colorClass}"></div>
          <span class="text-sm text-slate-300">${m.syndicate.name}</span>
        `;
        legendItemsEl.appendChild(itemEl);
      });
    }

    function populateSyndicateSelect() {
      syndicateSelectEl.innerHTML = '';
      currentData.memberships.forEach(m => {
        const option = document.createElement('option');
        option.value = m.syndicateId;
        option.textContent = m.syndicate.name;
        syndicateSelectEl.appendChild(option);
      });
    }

    function openCreateModal(dateStr) {
      if (!currentData.hasSyndicate) {
        alert('You need to join or create a syndicate first!');
        return;
      }
      
      selectedDateInput.value = dateStr;
      startDateInput.value = dateStr;
      endDateInput.value = dateStr;
      dateErrorEl.classList.add('hidden');
      reservationTitleInput.value = '';
      
      if (currentData.memberships.length === 1) {
        syndicateSelectEl.value = currentData.memberships[0].syndicateId;
      }
      
      createModalEl.classList.remove('hidden');
      createModalEl.classList.add('flex');
    }

    function closeCreateModal() {
      createModalEl.classList.add('hidden');
      createModalEl.classList.remove('flex');
    }

    function validateDates() {
      const startDate = startDateInput.value;
      const endDate = endDateInput.value;
      
      if (!startDate || !endDate) {
        return { valid: false, error: 'Please select both start and end dates' };
      }
      
      const start = new Date(startDate);
      const end = new Date(endDate);
      
      // Reset to midnight for accurate comparison
      start.setHours(0, 0, 0, 0);
      end.setHours(0, 0, 0, 0);
      
      if (end < start) {
        return { valid: false, error: 'End date must be after start date' };
      }
      
      // Calculate difference in days (inclusive)
      const diffTime = end.getTime() - start.getTime();
      const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
      
      // Max span is 7 days (end - start ≤ 6 days inclusive means 7 days total)
      if (diffDays > 6) {
        return { valid: false, error: 'Maximum reservation span is 7 days (end date must be within 6 days of start date)' };
      }
      
      return { valid: true, error: null };
    }

    async function createReservation(e) {
      e.preventDefault();
      
      const startDate = startDateInput.value;
      const endDate = endDateInput.value;
      const syndicateId = syndicateSelectEl.value;
      const title = reservationTitleInput.value;
      
      // Validate dates
      const validation = validateDates();
      if (!validation.valid) {
        dateErrorText.textContent = validation.error;
        dateErrorEl.classList.remove('hidden');
        return;
      }
      
      if (!syndicateId || !title) {
        alert('Please fill in all fields');
        return;
      }

      try {
        const startDateTime = new Date(startDate);
        const endDateTime = new Date(endDate);
        // Add one day to end date to make it exclusive (API expects exclusive end)
        endDateTime.setDate(endDateTime.getDate() + 1);

        await request(`/api/v1/syndicates/${syndicateId}/reservations`, {
          method: 'POST',
          body: JSON.stringify({
            title,
            startDate: startDateTime.toISOString(),
            endDate: endDateTime.toISOString()
          })
        });

        closeCreateModal();
        await loadDashboard();
      } catch (err) {
        alert('Error creating reservation: ' + err.message);
      }
    }

    async function loadDashboard() {
      try {
        const data = await request('/api/v1/dashboard');
        currentData = data;
        
        loadingEl.classList.add('hidden');
        
        if (!data.hasSyndicate) {
          noSyndicateCtaEl.classList.remove('hidden');
          calendarViewEl.classList.add('hidden');
        } else {
          noSyndicateCtaEl.classList.add('hidden');
          calendarViewEl.classList.remove('hidden');
          
          renderLegend();
          populateSyndicateSelect();
          renderCalendar(currentDate.getFullYear(), currentDate.getMonth());
        }
      } catch (e) {
        if (e.message !== "Session expired") {
          loadingEl.innerHTML = '<p class="text-red-400">Error: ' + (e.message || "Login required") + '</p>';
        }
      }
    }

    // Event listeners
    document.getElementById('prevMonth').addEventListener('click', () => {
      currentDate.setMonth(currentDate.getMonth() - 1);
      renderCalendar(currentDate.getFullYear(), currentDate.getMonth());
    });

    document.getElementById('nextMonth').addEventListener('click', () => {
      currentDate.setMonth(currentDate.getMonth() + 1);
      renderCalendar(currentDate.getFullYear(), currentDate.getMonth());
    });

    cancelModalBtn.addEventListener('click', closeCreateModal);
    createFormEl.addEventListener('submit', createReservation);
    
    // Real-time date validation
    startDateInput.addEventListener('change', () => {
      dateErrorEl.classList.add('hidden');
      // If end date is before new start date, reset end date to start date
      if (endDateInput.value && new Date(endDateInput.value) < new Date(startDateInput.value)) {
        endDateInput.value = startDateInput.value;
      }
    });
    
    endDateInput.addEventListener('change', () => {
      dateErrorEl.classList.add('hidden');
    });

    // Close modal on outside click
    createModalEl.addEventListener('click', (e) => {
      if (e.target === createModalEl) {
        closeCreateModal();
      }
    });

    // Initial load
    loadDashboard();
  </script>
</Protected>
