---
import Protected from "../layouts/Protected.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE || "http://localhost:3001";
---
<Protected title="JVZoo Settings">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">JVZoo Integration</h1>
    
    <div class="card">
      <div id="statusMessage" class="mb-4 p-3 rounded hidden"></div>
      
      <form id="jvzooForm" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-2" for="apiKey">
            JVZoo API Key
          </label>
          <input
            type="password"
            id="apiKey"
            name="apiKey"
            class="input w-full"
            placeholder="Enter your JVZoo API key"
          />
          <p class="text-sm text-slate-400 mt-1">
            Get your API key from your JVZoo account settings
          </p>
        </div>
        
        <button type="submit" class="btn" id="saveBtn">
          Save & Verify
        </button>
      </form>

      <div id="credentialsStatus" class="mt-6 hidden">
        <div class="border-t border-slate-700 pt-4">
          <h3 class="font-semibold mb-2">Current Status</h3>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span>API Key:</span>
              <span id="apiKeyStatus" class="font-mono"></span>
            </div>
            <div class="flex justify-between">
              <span>Verified:</span>
              <span id="verifiedStatus"></span>
            </div>
            <div class="flex justify-between" id="verifiedDateRow">
              <span>Verified At:</span>
              <span id="verifiedDate"></span>
            </div>
          </div>
          
          <button
            type="button"
            class="btn btn-danger mt-4"
            id="deleteBtn"
          >
            Remove API Key
          </button>
        </div>
      </div>

      <div class="mt-6 border-t border-slate-700 pt-4">
        <h3 class="font-semibold mb-2">Manual Import</h3>
        <p class="text-sm text-slate-400 mb-3">
          Trigger a manual import of your JVZoo transactions (for testing)
        </p>
        <button
          type="button"
          class="btn btn-secondary"
          id="importBtn"
        >
          Import Transactions Now
        </button>
        <p class="text-sm text-slate-400 mt-2" id="importMessage"></p>
      </div>
    </div>
  </div>

  <script define:vars={{ API_BASE }}>
    const jvzooForm = document.getElementById("jvzooForm");
    const apiKeyInput = document.getElementById("apiKey");
    const saveBtn = document.getElementById("saveBtn");
    const deleteBtn = document.getElementById("deleteBtn");
    const importBtn = document.getElementById("importBtn");
    const statusMessage = document.getElementById("statusMessage");
    const credentialsStatus = document.getElementById("credentialsStatus");
    const apiKeyStatus = document.getElementById("apiKeyStatus");
    const verifiedStatus = document.getElementById("verifiedStatus");
    const verifiedDate = document.getElementById("verifiedDate");
    const verifiedDateRow = document.getElementById("verifiedDateRow");
    const importMessage = document.getElementById("importMessage");
    const csrfToken = localStorage.getItem("csrfToken");

    async function request(path, options = {}) {
      const headers = { "Content-Type": "application/json" };
      if (csrfToken) headers["X-CSRF-Token"] = csrfToken;
      const res = await fetch(`${API_BASE}${path}`, {
        credentials: "include",
        headers,
        ...options,
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || "Request failed");
      return data;
    }

    function showStatus(message, type) {
      statusMessage.textContent = message;
      statusMessage.className = `mb-4 p-3 rounded ${
        type === "error" ? "bg-red-900/50 text-red-200" : "bg-green-900/50 text-green-200"
      }`;
      statusMessage.classList.remove("hidden");
    }

    async function loadCredentials() {
      try {
        const creds = await request("/api/v1/jvzoo/credentials");
        
        if (creds.configured) {
          credentialsStatus.classList.remove("hidden");
          apiKeyStatus.textContent = creds.apiKeyPrefix || "Configured";
          verifiedStatus.textContent = creds.verified ? "✓ Yes" : "✗ No";
          verifiedStatus.className = creds.verified ? "text-green-400" : "text-red-400";
          
          if (creds.verifiedAt) {
            verifiedDate.textContent = new Date(creds.verifiedAt).toLocaleDateString();
            verifiedDateRow.classList.remove("hidden");
          } else {
            verifiedDateRow.classList.add("hidden");
          }
          
          if (creds.verificationError) {
            showStatus(`Verification failed: ${creds.verificationError}`, "error");
          }
        } else {
          credentialsStatus.classList.add("hidden");
        }
      } catch (err) {
        console.error("Failed to load credentials:", err);
      }
    }

    jvzooForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const apiKey = apiKeyInput.value.trim();
      
      if (!apiKey) {
        showStatus("Please enter an API key", "error");
        return;
      }

      saveBtn.disabled = true;
      saveBtn.textContent = "Verifying...";

      try {
        await request("/api/v1/jvzoo/credentials", { method: "POST", body: JSON.stringify({ apiKey }) });
        showStatus("API key saved and verified successfully!", "success");
        apiKeyInput.value = "";
        await loadCredentials();
      } catch (err) {
        showStatus(err.message || "Verification failed", "error");
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = "Save & Verify";
      }
    });

    deleteBtn.addEventListener("click", async () => {
      if (!confirm("Are you sure you want to remove your JVZoo API key?")) {
        return;
      }

      try {
        await request("/api/v1/jvzoo/credentials", { method: "DELETE" });
        showStatus("API key removed", "success");
        credentialsStatus.classList.add("hidden");
      } catch (err) {
        showStatus("Failed to remove API key", "error");
      }
    });

    importBtn.addEventListener("click", async () => {
      importBtn.disabled = true;
      importBtn.textContent = "Importing...";
      importMessage.textContent = "";

      try {
        const result = await request("/api/v1/jvzoo/import", { method: "POST" });
        importMessage.textContent = `Imported ${result.imported} transactions, skipped ${result.skipped} (duplicates)`;
        importMessage.className = "text-sm text-green-400 mt-2";
      } catch (err) {
        importMessage.textContent = err.message || "Import failed";
        importMessage.className = "text-sm text-red-400 mt-2";
      } finally {
        importBtn.disabled = false;
        importBtn.textContent = "Import Transactions Now";
      }
    });

    loadCredentials();
  </script>
</Protected>
