DATABASE_URL="file:./dev.db"
JWT_SECRET="your-long-random-secret"
APP_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
JWT_EXPIRES_IN_SECONDS="1800"
REFRESH_TOKEN_TTL_DAYS="30"
